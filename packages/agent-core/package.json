{
  "name": "@mcagent/agent-core",
  "version": "0.0.10",
  "private": true,
  "description": "McAgent Agent Core - Electron + React 桌面客户端",
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "chcp 65001 > NUL & electron-vite dev",
    "predev": "node scripts/ensure-native.cjs electron",
    "build": "electron-vite build",
    "preview": "chcp 65001 > NUL & electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pretest": "node scripts/ensure-native.cjs node",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@heroui/react": "3.0.0-rc.1",
    "@heroui/styles": "3.0.0-rc.1",
    "@mcagent/shared": "workspace:*",
    "@types/node-cron": "^3.0.11",
    "archiver": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "chromadb": "^3.5.0",
    "dockerode": "^5.0.1",
    "electron-updater": "^6.3.0",
    "lucide-react": "^1.24.0",
    "node-cron": "^4.6.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^14.0.1",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.2.9",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^8.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.4.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "build": {
    "appId": "com.alice.agent-core",
    "productName": "Alice",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "copper-lamp",
      "repo": "Alice-App",
      "private": false,
      "releaseType": "release"
    }
  }
}
